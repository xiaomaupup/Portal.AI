# API
API_PORT=3001
JWT_SECRET=please-change-me
# 生产环境逗号分隔：后台与官网的完整 origin（含 https），解决浏览器跨域
# CORS_ORIGINS=https://admin.example.com,https://www.example.com

# MySQL (local docker)
MYSQL_DATABASE=portal_ai
MYSQL_USER=portal
MYSQL_PASSWORD=portal_pass
MYSQL_ROOT_PASSWORD=root_pass
MYSQL_PORT=3306

# Postgres (for Payload CMS)
POSTGRES_DB=portal_ai
POSTGRES_USER=portal
POSTGRES_PASSWORD=portal_pass
POSTGRES_PORT=5432

# Prisma connection string (apps/api)
DATABASE_URL="mysql://portal:portal_pass@localhost:3306/portal_ai"

